MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=...
JWT_SECRET=use-a-long-random-string-in-production
FRONTEND_URL=http://localhost:5173
BEDROCK_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key
# BEDROCK_API_KEY=your-bedrock-api-key
BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0
OCR_IMAGE_PROVIDER=bedrock
OCR_HEIC_PROVIDER=gemini
OCR_TEXT_PROVIDER=bedrock
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1beta
OCR_TEXT_CHAR_LIMIT=12000
OCR_MAX_RAW_TEXT_CHARS=50000
SPLITWISE_BASE_URL=https://secure.splitwise.com
SPLITWISE_API_BASE=https://secure.splitwise.com/api/v3.0
SPLITWISE_CLIENT_ID=your-splitwise-client-id
SPLITWISE_CLIENT_SECRET=your-splitwise-client-secret
SPLITWISE_REDIRECT_URI=http://localhost:5173/api/auth/splitwise/callback
SPLITWISE_STATE_SECRET=another-long-random-secret
